# Use internal service DNS when deploying as a Render blueprint (internal networking):
# BACKEND_URL=http://modular-component-showcase-backend:5000
# SPRING_SERVICE_URL=http://modular-component-showcase-springboot:8081
# For local development, use localhost values below.
BACKEND_URL=http://backend:5000
SPRING_SERVICE_URL=http://springboot:8081
FRONTEND_URL=http://localhost:8080
JWT_SECRET=replace-with-the-same-long-secret-as-backend
SPRING_JWT_SECRET=replace-with-the-same-long-secret-as-springboot
GATEWAY_PORT=8000
GATEWAY_HOST=0.0.0.0
LOG_LEVEL=info
DEBUG=false
REQUEST_TIMEOUT_SECONDS=20
REQUEST_MAX_RETRIES=2
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
