# Environment variables for Modular Component Showcase Application
# Backend email (SMTP) configuration
SMTP_USER=youraddress@gmail.com
SMTP_PASS=yourpassword
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=youraddress@gmail.com

# JWT secret for authentication (set to a long random string)
JWT_SECRET=your_jwt_secret

# MongoDB connection string
MONGODB_URI=your_mongodb_uri

# CORS and frontend origins (comma-separated)
FRONTEND_ORIGINS=http://localhost:5173

# Allow in-memory MongoDB fallback (for development only)
ALLOW_MEMORY_FALLBACK=true

# Node environment (development/production)
NODE_ENV=development

# Server port
PORT=5000
