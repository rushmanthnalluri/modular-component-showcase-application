# --- Shared database and service defaults ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB= you-should-set-this-to-your-postgres-db-name
MONGODB_URI=you-should-set-this-to-your-mongodb-uri
DATABASE_URL=you-should-set-this-to-your-database-url
PORT=5000
GATEWAY_PORT=8000
SPRING_SERVICE_PORT=8081
NODE_ENV=development

# --- JWT and CORS ---
JWT_SECRET=replace-with-a-long-random-secret
SPRING_JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:8081
SPRING_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:8000

# --- Frontend / gateway / observability ---
VITE_GATEWAY_URL=http://localhost:8000
VITE_USE_GATEWAY=true
BACKEND_URL=http://localhost:5000
SPRING_SERVICE_URL=http://localhost:8081
FRONTEND_URL=http://localhost:8080
REQUEST_TIMEOUT_SECONDS=20
REQUEST_MAX_RETRIES=2
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# --- Backend runtime toggles ---
ALLOW_MEMORY_FALLBACK=true
SQL_AUTO_MIGRATE=true
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=5000
PGSSL=false

# --- Optional SMTP / vector search ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@example.com
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
PGVECTOR_ENABLED=true
PGVECTOR_DIMENSIONS=128
EXTERNAL_VECTOR_PROVIDER=

# --- Spring service ---
SPRING_PROFILES_ACTIVE=dev
SPRING_JWT_EXPIRATION_MS=3600000
SPRING_JWT_REFRESH_EXPIRATION_MS=604800000
