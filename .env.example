###############################################
# Root .env.example for all services
# Copy to .env and fill in secrets for production
###############################################

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=modular_component_showcase_application
MONGODB_URI=mongodb://mongo:27017/modular_components
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/modular_component_showcase_application

# --- JWT Secrets ---
JWT_SECRET=your_secure_jwt_secret
SPRING_JWT_SECRET=your_spring_jwt_secret

# --- Service URLs ---
VITE_GATEWAY_URL=http://localhost:8000
VITE_USE_GATEWAY=true
FRONTEND_ORIGINS=http://localhost:8080,http://localhost:5173
SPRING_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:8000
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# --- Ports ---
PORT=5000
GATEWAY_PORT=8000

# JWT authentication secret - use a long random string in production
JWT_SECRET=ThBcXdcmLnjV9xOJkcv8BuQeYrZdXRKRj2dZE8VKM3yLkjd7vp5EELEUdM8V17Oj
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS - frontend origins allowed to call backend (comma-separated)
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8081

# Allow in-memory MongoDB fallback (development only, never enable in production)
ALLOW_MEMORY_FALLBACK=true

# PostgreSQL connection pool settings (optional, production)
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=5000
PGSSL=false

# Automatic schema migration (set to true to auto-migrate on startup)
SQL_AUTO_MIGRATE=true

# ============================================
# EMAIL/SMTP CONFIGURATION (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@example.com

# ============================================
# GATEWAY CONFIGURATION (FastAPI)
# ============================================
BACKEND_URL=http://localhost:5000
AUTH_SERVICE_URL=http://localhost:5000
SEARCH_SERVICE_URL=http://localhost:5000
SQL_SERVICE_URL=http://localhost:5000
COMPONENT_SERVICE_URL=http://localhost:5000
SPRING_SERVICE_URL=http://localhost:8081
FRONTEND_URL=http://localhost:8080
GATEWAY_PORT=8000
GATEWAY_HOST=0.0.0.0
LOG_LEVEL=info
DEBUG=false
REQUEST_TIMEOUT_SECONDS=20
REQUEST_MAX_RETRIES=2
JWT_ISSUER=modular-component-showcase
JWT_AUDIENCE=modular-component-showcase-clients
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ============================================
# VECTOR / SEARCH CONFIGURATION
# ============================================
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
PGVECTOR_ENABLED=false
EXTERNAL_VECTOR_PROVIDER=

# ============================================
# SPRING SERVICE CONFIGURATION (Spring Boot)
# ============================================
SPRING_SERVICE_PORT=8081
SPRING_PROFILES_ACTIVE=dev
SPRING_JWT_SECRET=replace-with-a-strong-32-char-min-secret
SPRING_JWT_EXPIRATION_MS=3600000
SPRING_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:8000

