# Shared environment variables for the monorepo root
# Keep this file minimal and only place cross-service values here.
# Frontend-specific variables belong in frontend/.env.example
# Backend-specific variables belong in backend/.env.example
# Gateway-specific variables belong in gateway/.env.example

# Shared deployment metadata
APP_NAME=Modular Component Showcase Application
NODE_VERSION=20
# ============================================
# Modular Component Showcase Application
# Environment Configuration Template
# ============================================
# Copy this file to .env and fill in with your values
# Never commit .env to version control
# This is the single source of truth for frontend, backend, and gateway env variables.

# ============================================
# FRONTEND CONFIGURATION (Vite)
# ============================================
VITE_API_BASE_URL=http://localhost:5000/api
VITE_GATEWAY_URL=http://localhost:8000
VITE_USE_GATEWAY=true
VITE_APP_NAME=Modular Component Showcase Application

# ============================================
# BACKEND CONFIGURATION (Express)
# ============================================
PORT=5000
NODE_ENV=development

# MongoDB - for component data, search, discussions, reviews
# Production: Use MongoDB Atlas URI
# Development: Can use local MongoDB or in-memory fallback
MONGODB_URI=mongodb://localhost:27017/modular_components

# PostgreSQL - for SQL catalog and user management
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/modular_component_showcase_application

# JWT authentication secret - use a long random string in production
JWT_SECRET=ThBcXdcmLnjV9xOJkcv8BuQeYrZdXRKRj2dZE8VKM3yLkjd7vp5EELEUdM8V17Oj
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS - frontend origins allowed to call backend (comma-separated)
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8081

# Allow in-memory MongoDB fallback (development only, never enable in production)
ALLOW_MEMORY_FALLBACK=true

# PostgreSQL connection pool settings (optional, production)
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=5000
PGSSL=false

# Automatic schema migration (set to true to auto-migrate on startup)
SQL_AUTO_MIGRATE=true

# ============================================
# EMAIL/SMTP CONFIGURATION (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@example.com

# ============================================
# GATEWAY CONFIGURATION (FastAPI)
# ============================================
BACKEND_URL=http://localhost:5000
AUTH_SERVICE_URL=http://localhost:5000
SEARCH_SERVICE_URL=http://localhost:5000
SQL_SERVICE_URL=http://localhost:5000
COMPONENT_SERVICE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:8080
GATEWAY_PORT=8000
GATEWAY_HOST=0.0.0.0
LOG_LEVEL=info
DEBUG=false
REQUEST_TIMEOUT_SECONDS=20
REQUEST_MAX_RETRIES=2

