{
  "title": "Service Health and Throughput",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Backend Requests",
      "targets": [
        { "expr": "app_requests_total" }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Backend Errors",
      "targets": [
        { "expr": "app_errors_total" }
      ],
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Spring HTTP Requests",
      "targets": [
        { "expr": "http_server_requests_seconds_count" }
      ],
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 }
    },
    {
      "type": "stat",
      "title": "Gateway Requests",
      "targets": [
        { "expr": "gateway_requests_total" }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Gateway Errors",
      "targets": [
        { "expr": "gateway_errors_total" }
      ],
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 }
    }
  ]
}
