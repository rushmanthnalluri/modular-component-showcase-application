# Spring Service Environment Example
PORT=8081
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/modular_component_showcase_application
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes
SPRING_JWT_EXPIRATION_MS=3600000
SPRING_JWT_REFRESH_EXPIRATION_MS=604800000
SPRING_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:8000
SPRING_PROFILES_ACTIVE=production
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
