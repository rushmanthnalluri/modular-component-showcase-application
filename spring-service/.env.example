# Spring service runtime
SPRING_SERVICE_PORT=8081
SPRING_APP_NAME=spring-service
SPRING_PROFILES_ACTIVE=dev

# Use same DATABASE_URL pattern as backend
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/modular_component_showcase_application

# JWT settings
SPRING_JWT_SECRET=replace-with-a-strong-32-char-min-secret
SPRING_JWT_EXPIRATION_MS=3600000

# CORS
SPRING_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:8000

# Logging
SPRING_LOG_LEVEL=INFO
SPRING_REQUEST_LOGGING_ENABLED=true
